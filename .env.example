# Copy to .env and adjust as needed.

# SLURM version to build from source (must exist at https://download.schedmd.com/slurm/)
SLURM_VERSION=25.05.3

# Base image. Defaults to rockylinux:9 (multi-arch: amd64 + arm64).
# For GPU nodes the gpu profile uses nvidia/cuda:12.6.1-base-rockylinux9 automatically.
BASE_IMAGE=rockylinux:9

# Name of the local image tag built by `make build`
IMAGE_TAG=hpc-slurm-lab:latest

# Host port published by the SSH login node (maps to :22 in the container).
# This is the port you point `ssh` or a remote-agent client at. Change it if
# 2222 is already taken on your machine.
SSH_PORT=2222

# Password for the `admin` user on the SSH login node. Defaults to "admin"
# when unset — a zero-config local/home lab so you can `ssh admin@host` (and
# `ssh-copy-id` a key) with no setup. DEV/HOME-LAN ONLY; do not expose to the
# internet. Set to empty (SSH_PASSWORD=) for strict key-only auth.
SSH_PASSWORD=admin

# Number of CPU compute nodes (c1..cN) launched by docker compose
CPU_NODES=2

# GPU node settings (only used with `make up-gpu`)
GPU_GRES=gpu:rtx:1
GPU_FEATURES=gpu
